# Usuário do painel administrativo
ADMIN_USERNAME=admin

# Hash bcrypt da senha (definido com: npm run set-password)
ADMIN_PASSWORD_HASH=

# Segredo da sessão — troque por uma string longa e aleatória
SESSION_SECRET=troque-por-uma-chave-secreta-longa

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# URL pública do site (usada para canonical, OG, sitemap)
SITE_URL=https://draalanalibrelon.com.br
