<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog | Painel Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@600&family=Nunito:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
  <style>
    .blog-admin-lista { display: grid; gap: 14px; }
    .blog-admin-card {
      background: white;
      border: 2px solid var(--rosa-doce);
      border-radius: 16px;
      padding: 18px 20px;
      display: grid;
      grid-template-columns: 80px 1fr auto;
      gap: 16px;
      align-items: center;
    }
    .blog-admin-card img {
      width: 80px; height: 56px; object-fit: cover;
      border-radius: 10px; background: var(--rosa-doce);
    }
    .blog-admin-info h3 { font-size: 1rem; margin: 0 0 4px; }
    .blog-admin-info p { font-size: 0.8rem; color: var(--grafite-medio); margin: 0; }
    .blog-admin-cats { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 6px; }
    .mini-tag {
      background: var(--rosa-doce); color: var(--rosa-profundo);
      font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
      padding: 2px 8px; border-radius: 999px; letter-spacing: 0.04em;
    }
    .blog-admin-acoes { display: flex; gap: 8px; flex-shrink: 0; }
    .btn-editar, .btn-ver {
      padding: 8px 16px; border-radius: 999px; font-size: 0.8rem;
      font-weight: 700; text-decoration: none; border: none; cursor: pointer;
      font-family: var(--fonte-corpo);
    }
    .btn-editar { background: var(--rosa-flor); color: white; }
    .btn-editar:hover { background: var(--rosa-profundo); }
    .btn-ver { background: var(--menta-doce); color: #205442; }
    .btn-ver:hover { filter: brightness(0.95); }
    .btn-deletar { background: #FBE1E1; color: #9C3B3B; }
    .blog-vazio-admin { text-align: center; padding: 60px 20px; color: var(--grafite-medio); }
    .blog-vazio-admin svg { width: 56px; color: var(--rosa-doce); margin-bottom: 16px; }
    .btn-novo-artigo {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--rosa-flor); color: white; font-weight: 700;
      padding: 12px 24px; border-radius: 999px; text-decoration: none;
      font-family: var(--fonte-corpo); font-size: 0.9rem;
      transition: background 0.15s;
    }
    .btn-novo-artigo:hover { background: var(--rosa-profundo); }
    @media (max-width: 600px) {
      .blog-admin-card { grid-template-columns: 1fr; }
      .blog-admin-card img { width: 100%; height: 120px; }
      .blog-admin-acoes { flex-wrap: wrap; }
    }
  </style>
</head>
<body>

  <header class="topo-admin">
    <div class="marca-admin">
      <svg viewBox="0 0 40 40" fill="none" width="32" height="32">
        <path d="M20 6c-6 0-10 3.5-10 10 0 6.5 2.5 10 3.5 15 .5 2.8 3.6 2.6 4.1 0 .5-2.6 1-5 2.4-5s1.9 2.4 2.4 5c.5 2.6 3.6 2.8 4.1 0C27.5 26 30 22.5 30 16c0-6.5-4-10-10-10Z" fill="#EE93AF"/>
      </svg>
      <span>Painel Admin</span>
    </div>
    <div class="acoes-topo">
      <a href="/admin" class="botao-admin secundario">← Conteúdo</a>
      <a href="/" class="botao-admin secundario" target="_blank">Ver site</a>
      <form action="/admin/logout" method="POST" style="margin:0">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button type="submit" class="botao-admin sair">Sair</button>
      </form>
    </div>
  </header>

  <div style="max-width:1100px; margin:0 auto; padding:28px 24px 80px;">

    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:28px;">
      <div>
        <h1 style="margin:0 0 4px">Blog</h1>
        <p style="margin:0; color:var(--grafite-medio); font-size:0.9rem;"><%= artigos.length %> artigo(s) publicado(s)</p>
      </div>
      <a href="/admin/blog/novo" class="btn-novo-artigo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="16" height="16">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        Novo artigo
      </a>
    </div>

    <% if (sucesso) { %>
      <div class="alerta-sucesso">✅ <%= sucesso %></div>
    <% } %>
    <% if (erro) { %>
      <div class="alerta-erro">❌ <%= erro %></div>
    <% } %>

    <% if (artigos.length === 0) { %>
      <div class="painel blog-vazio-admin">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>
        </svg>
        <h3>Nenhum artigo ainda</h3>
        <p>Crie seu primeiro artigo para o blog!</p>
        <a href="/admin/blog/novo" class="btn-novo-artigo" style="display:inline-flex; margin-top:16px">+ Criar primeiro artigo</a>
      </div>
    <% } else { %>
      <div class="blog-admin-lista">
        <% artigos.forEach(function(a) { %>
          <div class="blog-admin-card">
            <img
              src="<%= a.coverImage %>"
              alt="<%= a.coverImageAlt || a.title %>"
              onerror="this.src='data:image/svg+xml,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'80\' height=\'56\'><rect width=\'80\' height=\'56\' fill=\'%23F8CBDA\'/></svg>'"
            >
            <div class="blog-admin-info">
              <h3><%= a.title %></h3>
              <p><%= new Date(a.date + 'T12:00:00').toLocaleDateString('pt-BR') %> · <%= a.readingTimeMinutes %> min de leitura</p>
              <div class="blog-admin-cats">
                <% (a.categories || []).forEach(function(cat) { %>
                  <span class="mini-tag"><%= cat %></span>
                <% }); %>
              </div>
            </div>
            <div class="blog-admin-acoes">
              <a href="/admin/blog/editar/<%= a.slug %>" class="btn-editar">✏️ Editar</a>
              <a href="/blog/<%= a.slug %>/" class="btn-ver" target="_blank">👁 Ver</a>
              <form action="/admin/blog/deletar" method="POST" onsubmit="return confirm('Deletar o artigo &quot;<%= a.title %>&quot;? Esta ação não pode ser desfeita.')">
                <input type="hidden" name="_csrf" value="<%= csrf %>">
                <input type="hidden" name="slug" value="<%= a.slug %>">
                <button type="submit" class="btn-editar btn-deletar">🗑 Deletar</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</body>
</html>
